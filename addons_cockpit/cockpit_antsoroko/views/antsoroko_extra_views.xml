<odoo>
  <data>

    <!-- Vue liste -->
    <record id="view_antsoroko_extra_tree" model="ir.ui.view">
      <field name="name">antsoroko.extra.tree</field>
      <field name="model">antsoroko.extra</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name"/>
          <field name="date"/>
          <field name="heure"/>
          <field name="vehicule"/>
          <field name="client"/>
          <field name="type_mouvement"/>
          <field name="nb_sacs"/>
          <field name="cumul_sacs"/>
          <field name="quantite"/>
          <field name="cumul_quantite"/>
          <field name="prix_kg"/>
          <field name="montant_paye"/>
          <field name="cumul_montant"/>
          <field name="stock"/>
          <field name="remarque"/>
        </tree>
      </field>
    </record>

    <!-- Vue formulaire -->
    <record id="view_antsoroko_extra_form" model="ir.ui.view">
      <field name="name">antsoroko.extra.form</field>
      <field name="model">antsoroko.extra</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name" readonly="1"/>
              <field name="date"/>
              <field name="heure"/>
              <field name="vehicule"/>
              <field name="client"/>
              <field name="type_mouvement" readonly="1"/>
            </group>
            <group>
              <field name="nb_sacs"/>
              <field name="cumul_sacs" readonly="1"/>
              <field name="quantite"/>
              <field name="cumul_quantite" readonly="1"/>
              <field name="prix_kg"/>
              <field name="montant_paye"/>
              <field name="cumul_montant" readonly="1"/>
              <field name="stock"/>
            </group>
            <group>
              <field name="remarque"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Vue recherche -->
    <record id="view_antsoroko_extra_search" model="ir.ui.view">
      <field name="name">antsoroko.extra.search</field>
      <field name="model">antsoroko.extra</field>
      <field name="arch" type="xml">
        <search>
          <field name="name"/>
          <field name="vehicule"/>
          <field name="client"/>
          <filter string="Client Jean" domain="[('client','=','Jean')]" name="filter_client_jean"/>
          <filter string="Client Solo" domain="[('client','=','Solo')]" name="filter_client_solo"/>
        </search>
      </field>
    </record>

    <!-- Action -->
    <record id="action_antsoroko_extra" model="ir.actions.act_window">
      <field name="name">Antsoroko Extra</field>
      <field name="res_model">antsoroko.extra</field>
      <field name="view_mode">tree,form</field>
      <field name="search_view_id" ref="view_antsoroko_extra_search"/>
    </record>


  </data>
</odoo>

