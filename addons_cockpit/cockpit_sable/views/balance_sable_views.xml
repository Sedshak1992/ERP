<odoo>
  <data>

    <!-- Vue liste (tableau cockpit) -->
    <record id="view_balance_sable_tree" model="ir.ui.view">
      <field name="name">balance.sable.tree</field>
      <field name="model">balance.sable</field>
      <field name="arch" type="xml">
        <tree>
          <field name="date"/>
          <field name="camion"/>
          <field name="client"/>
          <field name="quantite_entree"/>
          <field name="quantite_sortie"/>
          <field name="stock_restant"/>
          <field name="ecart"/>
          <field name="remarque"/>
        </tree>
      </field>
    </record>

    <!-- Vue formulaire cockpit -->
    <record id="view_balance_sable_form" model="ir.ui.view">
      <field name="name">balance.sable.form</field>
      <field name="model">balance.sable</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="date"/>
              <field name="camion"/>
              <field name="client"/>
            </group>
            <group>
              <field name="quantite_entree"/>
              <field name="quantite_sortie"/>
              <field name="stock_restant" readonly="1"/>
              <field name="ecart" readonly="1"/>
            </group>
            <group>
              <field name="remarque"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Vue recherche cockpit -->
    <record id="view_balance_sable_search" model="ir.ui.view">
      <field name="name">balance.sable.search</field>
      <field name="model">balance.sable</field>
      <field name="arch" type="xml">
        <search>
          <field name="camion"/>
          <field name="client"/>
          <field name="date"/>
        </search>
      </field>
    </record>

    <!-- Action cockpit -->
    <record id="action_balance_sable" model="ir.actions.act_window">
      <field name="name">Balance Sable</field>
      <field name="res_model">balance.sable</field>
      <field name="view_mode">tree,form</field>
      <field name="search_view_id" ref="view_balance_sable_search"/>
    </record>


  </data>
</odoo>

