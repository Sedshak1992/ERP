<odoo>
    <record id="rule_operator_own_files" model="ir.rule">
        <field name="name">Operator Own Files</field>
        <field name="model_id" ref="base.model_ir_attachment"/>
        <field name="groups" eval="[(4, ref('cockpit_security.group_cockpit_operator'))]"/>
        <field name="domain_force">[('create_uid','=',user.id)]</field>
    </record>

    <record id="rule_supervisor_all_files" model="ir.rule">
        <field name="name">Supervisor All Files</field>
        <field name="model_id" ref="base.model_ir_attachment"/>
        <field name="groups" eval="[(4, ref('cockpit_security.group_cockpit_supervisor'))]"/>
        <field name="domain_force">[]</field>
    </record>
</odoo>

